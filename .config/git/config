[user]
	# identity(name/email) は公開 dotfiles に持たせない方針（各マシンでローカル設定）。
	# 未設定のまま commit すると `名前@ホスト名` が焼き付くため useConfigOnly で防ぐ。
	# (未設定なら commit がエラーになる = 社内ホスト名などの混入事故対策)
	useConfigOnly = true
[alias]
	st = status
	lg = log
	# 一行で表示する
	lgo = log --oneline
	# 特定のファイルのログを表示する
	lgp = log -p
	lg-show-author = log --pretty=full
	graph = log --graph --date=short --decorate=short --pretty=format:'%Cgreen%h %Creset%cd %Cblue%cn %Cred%d %Creset%s'
	# 上の省略形
	gr = log --graph --date=short --decorate=short --pretty=format:'%Cgreen%h %Creset%cd %Cblue%cn %Cred%d %Creset%s'
	st = status
	sts = status -s
	stsb = status -sb
	cm = commit
	cmm = commit -m
	cmam = commit -am
	cmamd = commit --amend
	cmamdm = commit --amend -m
	br = branch
	co = checkout
	# Untracked filesを表示せず，not stagedと，stagedだけの状態を出力する
	stt = status -uno
	# 行ごとの差分じゃなくて，単語レベルでの差分を色付きで表示する
	difff = diff --word-diff
	diffc = diff --cached
	diffno = diff --name-only
	merge-dry = merge --no-commit --no-ff
	subtree-ls = !"git log | grep git-subtree-dir |  awk '{ print $2}'"
	submoulde-ls = !"git config --file .gitmodules --get-regexp path | awk '{ print $2}'"
	remote-open = !"git remote -v | awk '{ print $2}' | peco | xargs open"
	root = rev-parse --show-toplevel
	root-cd = !"cd $(git rev-parse --show-toplevel)"
	restores = restore --staged
	restore-all = !"git sts | awk '{print $2}' | xargs git restore --staged "
[color]
	ui = auto
[core]
	editor = vim
	attributesfile = ~/.config/git/attributes
	excludesfile = ~/.config/git/ignore
	# 全 repo 共通の pre-commit / pre-push フック（gitleaks スキャン）
	hooksPath = ~/.config/git/hooks
[filter "lfs"]
	clean = git-lfs clean %f
	smudge = git-lfs smudge %f
	required = true
[diff "xlsx"]
	binary = true
	textconv = $GOPATH/bin/git-xlsx-textconv
[ghq]
	root = ~/src
[hub]
	protocol = https
[include]
	# 各マシン固有の設定（identity 等）はここに分離。dotfiles の外・非追跡。
	# 例) ~/.config/git/config.local に [user] name/email を記載（無ければ git は無視）。
	path = ~/.config/git/config.local
