# ~/.config/ghostty/config
# Run `ghostty +show-config --default --docs` to see all options
# Run `ghostty +list-themes` to see all built-in themes
# Run `ghostty +list-fonts` to see available fonts

# ── Theme ──────────────────────────────────────────────────────────────────
# Popular choices: Catppuccin Mocha, Catppuccin Macchiato, tokyonight-storm,
#   Gruvbox Dark Hard, Dark+, Dracula, nord
theme = light:Gruvbox Light Hard,dark:Gruvbox Dark Hard

# ── Font ───────────────────────────────────────────────────────────────────
# Popular: JetBrainsMono Nerd Font, FiraCode Nerd Font, Cascadia Mono NF
# Ghostty ships with JetBrains Mono built-in as the default
font-family = JetBrainsMono Nerd Font
font-size = 14
font-thicken = true

# ── Cursor ─────────────────────────────────────────────────────────────────
cursor-style = block
cursor-style-blink = false
# Note: cursor-style-blink is ignored when shell integration is active.
# Use this to force it off:
shell-integration-features = no-cursor

# ── Window ─────────────────────────────────────────────────────────────────
window-padding-x = 8
window-padding-y = 8
window-padding-balance = true
window-save-state = always
macos-titlebar-style = tabs
background-opacity = 0.95
background-blur = 20

# Unfocused split dimming
unfocused-split-opacity = 0.80

# ── Behavior ───────────────────────────────────────────────────────────────
mouse-hide-while-typing = true
copy-on-select = clipboard
confirm-close-surface = false
resize-overlay = never
macos-option-as-alt = left   # left=Alt, right=Option (useful for macOS shortcuts)

# ── Quick Terminal ─────────────────────────────────────────────────────────
quick-terminal-position = center
quick-terminal-animation-duration = 0.05
quick-terminal-size = 70%,70%

# ── Keybindings ────────────────────────────────────────────────────────────
# Splits
keybind = super+d=new_split:right
keybind = super+shift+d=new_split:down
keybind = super+shift+enter=toggle_split_zoom
keybind = super+ctrl+left=goto_split:left
keybind = super+ctrl+right=goto_split:right
keybind = super+ctrl+up=goto_split:top
keybind = super+ctrl+down=goto_split:bottom
keybind = super+ctrl+alt+left=resize_split:left,10
keybind = super+ctrl+alt+right=resize_split:right,10
keybind = super+ctrl+alt+up=resize_split:up,10
keybind = super+ctrl+alt+down=resize_split:down,10
keybind = cmd+shift+equal=equalize_splits

# Tabs
keybind = super+t=new_tab
keybind = super+alt+right=next_tab
keybind = super+alt+left=previous_tab
keybind = super+physical:one=goto_tab:1
keybind = super+physical:two=goto_tab:2
keybind = super+physical:three=goto_tab:3
keybind = super+physical:four=goto_tab:4
keybind = super+physical:five=goto_tab:5

# Window management
keybind = super+n=new_window
keybind = super+w=close_surface
keybind = super+shift+w=close_window
keybind = super+ctrl+f=toggle_fullscreen
keybind = super+q=quit

# Clipboard
keybind = super+c=copy_to_clipboard
keybind = super+v=paste_from_clipboard
keybind = super+a=select_all

# Font size
keybind = super+equal=increase_font_size:1
keybind = super+minus=decrease_font_size:1
keybind = super+zero=reset_font_size

# Scrolling
keybind = super+home=scroll_to_top
keybind = super+end=scroll_to_bottom
keybind = super+page_up=scroll_page_up
keybind = super+page_down=scroll_page_down

# Misc
keybind = super+k=clear_screen
keybind = super+p=toggle_command_palette

# Claude Code: shift+enter sends newline without submitting
keybind = shift+enter=text:\n

# Global quick terminal toggle (works from any app)
keybind = global:super+'=toggle_quick_terminal
